# src/api/.env.example
# local dev only; don't commit /api/.env
DB_AUTH=sql
SQL_SERVER=ember-sql.database.windows.net
SQL_DATABASE=ember-sql-db

# only for local sql auth
SQL_USER=
SQL_PASSWORD=
NODE_ENV=development
DEV_AUTH=1
DEV_USER_OID=local-dev-user
DEV_USER_EMAIL=
DEV_USER_NAME=
DEV_ROLES=gebruiker,admin
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173